{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Finguard Rasa custom json_message payloads",
  "description": "Shapes emitted by backend action handlers via dispatcher.utter_message(json_message=...).",
  "oneOf": [
    {
      "type": "object",
      "required": ["type", "text", "transaction"],
      "properties": {
        "type": { "const": "transaction_pending" },
        "text": { "type": "string" },
        "transaction": {
          "type": "object",
          "required": ["id", "type", "amount", "category", "date"],
          "properties": {
            "id": { "type": "string" },
            "type": { "enum": ["income", "expense", "pending"] },
            "amount": { "type": "number", "minimum": 0 },
            "category": { "type": "string" },
            "description": { "type": ["string", "null"] },
            "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["type", "text", "data"],
      "properties": {
        "type": { "const": "balance" },
        "text": { "type": "string" },
        "data": {
          "type": "object",
          "required": ["period", "income", "expenses", "net", "currency"],
          "properties": {
            "period": { "type": "string" },
            "income": { "type": "number" },
            "expenses": { "type": "number" },
            "net": { "type": "number" },
            "currency": { "type": "string" },
            "sentiment": { "type": "string" }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["type", "text", "data"],
      "properties": {
        "type": { "const": "spending_report" },
        "text": { "type": "string" },
        "data": {
          "type": "object",
          "required": ["period", "total", "currency", "by_category"],
          "properties": {
            "period": { "type": "string" },
            "total": { "type": "number" },
            "currency": { "type": "string" },
            "by_category": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["category", "total", "count"],
                "properties": {
                  "category": { "type": "string" },
                  "total": { "type": "number" },
                  "count": { "type": "integer" }
                }
              }
            }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["type", "text", "data"],
      "properties": {
        "type": { "const": "transaction_list" },
        "text": { "type": "string" },
        "data": {
          "type": "object",
          "required": ["count", "transactions"],
          "properties": {
            "count": { "type": "integer" },
            "transactions": { "type": "array" }
          }
        }
      }
    }
  ]
}
