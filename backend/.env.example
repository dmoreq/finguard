# ─── Environment ────────────────────────────────────────────────
ENV=development                    # development | production
PORT=5055

# ─── LLM Providers ───────────────────────────────────────────────
GEMINI_API_KEY=                    # Google AI Studio → free tier
DEEPSEEK_API_KEY=                  # platform.deepseek.com → fallback

# ─── LiteLLM ─────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-finguard-local   # internal key for Rasa → LiteLLM auth
LITELLM_API_BASE=http://litellm:4000   # LiteLLM proxy address (for local dev)

# ─── Supabase ────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=           # service role — only for backend!

# ─── Rasa ────────────────────────────────────────────────────────
RASA_ACTION_SERVER_URL=http://localhost:5055/webhook
RASA_URL=http://localhost:5005
