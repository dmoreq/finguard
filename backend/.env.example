# Optional: cloud LLM for richer extraction (rules work without this)
GEMINI_API_KEY=
LLM_EXTRACT_ENABLED=false
GEMINI_MODEL=gemini-2.0-flash

# Routing: keyword | semantic | hybrid (default hybrid when model cached locally)
ROUTER_MODE=hybrid
SEMANTIC_ROUTER_THRESHOLD=0.72

# CI: set to skip utterance-bank test that loads embeddings
# CI_NO_SEMANTIC=1

# Optional: override SQLite path (default: backend/data/finguard.db)
# FINGUARD_DB_PATH=

ENV=development
