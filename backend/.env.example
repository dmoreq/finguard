# Rasa Pro license — leave empty to use mock Rasa on :5005 (see scripts/mock-rasa.py)
# https://rasa.com/docs/pro/installation/licensing/
RASA_PRO_LICENSE=

# LLM keys (LiteLLM on host reads these)
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
LITELLM_MASTER_KEY=dev-local-key

# Optional: override SQLite path (default: backend/data/finguard.db)
# FINGUARD_DB_PATH=

ENV=development
