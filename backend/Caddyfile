# Development Caddyfile — simple reverse proxy
# For production, use real domain and enable auto HTTPS

localhost:80 {
	encode gzip

	# Rasa REST API
	handle /webhooks/* {
		reverse_proxy rasa:5005
	}

	# Health checks
	handle /health {
		reverse_proxy rasa:5005
	}

	# Default response
	handle {
		respond "Finguard Rasa CALM Backend" 200
	}
}
